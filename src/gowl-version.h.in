#ifndef GOWL_VERSION_H
#define GOWL_VERSION_H

/**
 * GOWL_VERSION_MAJOR:
 *
 * The major version number of gowl.
 */
#define GOWL_VERSION_MAJOR @GOWL_VERSION_MAJOR@

/**
 * GOWL_VERSION_MINOR:
 *
 * The minor version number of gowl.
 */
#define GOWL_VERSION_MINOR @GOWL_VERSION_MINOR@

/**
 * GOWL_VERSION_MICRO:
 *
 * The micro version number of gowl.
 */
#define GOWL_VERSION_MICRO @GOWL_VERSION_MICRO@

/**
 * GOWL_VERSION:
 *
 * The version string of gowl.
 */
#define GOWL_VERSION_STRING "@GOWL_VERSION@"

#endif /* GOWL_VERSION_H */
